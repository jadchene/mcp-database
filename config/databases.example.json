      }
    },
    {
      "key": "oracle-thick-example",
      "type": "oracle",
      "readonly": true,
      "connection": {
        "host": "127.0.0.1",
        "port": 1521,
        "serviceName": "XEPDB1",
        "user": "app_reader",
        "password": "replace-with-password",
        "connectTimeoutMs": 5000,
        "clientMode": "thick",
        "clientLibDir": "C:\\oracle\\instantclient_19_25"
      }
    }
  ]
